# =============================================================================
# takos-computer environment variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables are optional unless noted otherwise.

# -----------------------------------------------------------------------------
# Service Ports & Lifecycle
# -----------------------------------------------------------------------------

# HTTP port for sandbox-service and dashboard worker (default: 8080)
# PORT=8080

# Grace period in ms before forceful shutdown (default: 15000)
# SHUTDOWN_GRACE_MS=15000

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Required in deployed prod/staging sandbox-host environments.
# Worker-to-container /mcp auth. The sandbox service receives this as
# MCP_AUTH_TOKEN, but shell child processes do not inherit it.
# Set with: wrangler secret put MCP_AUTH_TOKEN -c deploy/wrangler.sandbox-host.toml
# Set with: wrangler secret put MCP_AUTH_TOKEN -c deploy/wrangler.sandbox-host.toml --env staging
# MCP_AUTH_TOKEN=

# Required for sandbox-host worker admin/session routes.
# Set with: wrangler secret put SANDBOX_HOST_AUTH_TOKEN -c deploy/wrangler.sandbox-host.toml
# Set with: wrangler secret put SANDBOX_HOST_AUTH_TOKEN -c deploy/wrangler.sandbox-host.toml --env staging
# SANDBOX_HOST_AUTH_TOKEN=

# Trust Takos dispatch-routed GUI/API requests carrying X-Takos-Internal-Marker.
# The Takos manifest sets this for managed deploys; only set it behind a router
# that strips external X-Takos-Internal-Marker headers before adding its own.
# TAKOS_TRUST_ROUTED_GUI_API=1

# Optional Takos CLI credentials injected into sandbox containers.
# Prefer managed Takos API key consume in .takos/app.yml for Takos deploys.
# TAKOS_API_URL=
# TAKOS_TOKEN=
