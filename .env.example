# =============================================================================
# takos-computer environment variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables are optional unless noted otherwise.

# -----------------------------------------------------------------------------
# LLM API Keys
# At least one provider key is required to run the agent.
# -----------------------------------------------------------------------------

# OpenAI API key (required for GPT models, used as default provider)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key (required for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google AI API key (required for Gemini models)
GOOGLE_API_KEY=your-google-api-key

# -----------------------------------------------------------------------------
# LLM Model Configuration
# -----------------------------------------------------------------------------

# Override the default LLM model ID (e.g. "gpt-4o", "claude-sonnet-4-20250514")
# AI_MODEL=

# Force a specific provider: "openai" | "anthropic" | "google"
# AI_PROVIDER=

# -----------------------------------------------------------------------------
# Search API
# -----------------------------------------------------------------------------

# Serper.dev API key for web search tool
# SERPER_API_KEY=your-serper-api-key

# -----------------------------------------------------------------------------
# Service URLs (required for executor-service container)
# -----------------------------------------------------------------------------

# Base URL of the Takos control-plane worker (required for executor /start)
CONTROL_RPC_BASE_URL=https://your-control-plane.workers.dev

# Base URL of the executor proxy (optional, used alongside CONTROL_RPC_BASE_URL)
# PROXY_BASE_URL=

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------

# Admin panel domain
# ADMIN_DOMAIN=admin.takos.dev

# Tenant application base domain
# TENANT_BASE_DOMAIN=app.takos.dev

# -----------------------------------------------------------------------------
# Service Ports & Lifecycle
# -----------------------------------------------------------------------------

# HTTP port for executor-service and browser-service (default: 8080)
# PORT=8080

# Max concurrent agent runs for executor-service (default: 5)
# MAX_CONCURRENT_RUNS=5

# Grace period in ms before forceful shutdown — executor (default: 30000)
# SHUTDOWN_GRACE_MS=30000

# -----------------------------------------------------------------------------
# Agent Tuning
# -----------------------------------------------------------------------------

# Maximum number of LLM iterations per run (default: 10000)
# MAX_AGENT_ITERATIONS=10000

# LLM sampling temperature 0.0-1.0 (default: 0.5)
# AGENT_TEMPERATURE=0.5

# Rate limit for agent requests (requests per window)
# AGENT_RATE_LIMIT=

# Per-iteration timeout in ms (default: 120000 = 2 min)
# AGENT_ITERATION_TIMEOUT=120000

# Total run timeout in ms (default: 900000 = 15 min; container mode supports up to 86400000 = 24h)
# AGENT_TOTAL_TIMEOUT=900000

# Per-tool execution timeout in ms (default: 300000 = 5 min)
# TOOL_EXECUTION_TIMEOUT=300000

# LangGraph execution timeout in ms (default: 900000 = 15 min)
# LANGGRAPH_TIMEOUT=900000

# Enable R2-based message offloading ("true" to enable)
# TAKOS_OFFLOAD_ENABLED=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Allow agent to run without an LLM key configured (true/false/1/0/yes/no)
# TAKOS_ALLOW_NO_LLM=false

# Local-only alias for TAKOS_ALLOW_NO_LLM (lower precedence)
# TAKOS_LOCAL_ALLOW_NO_LLM=false

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Access token for Takos control-plane API (required by takopack deploy)
# TAKOS_ACCESS_TOKEN=

# Auth token for browser-service MCP endpoint (auto-generated in production)
# MCP_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Actions Engine (GitHub Actions-compatible runner paths)
# -----------------------------------------------------------------------------

# Temporary directory for runner steps (default: /tmp)
# RUNNER_TEMP=/tmp

# Tool cache directory (default: /opt/hostedtoolcache)
# RUNNER_TOOL_CACHE=/opt/hostedtoolcache

# Enable runner debug logging (set to "1" to enable)
# RUNNER_DEBUG=
