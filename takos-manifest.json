{
  "$schema": "https://takos.dev/schemas/manifest/v1.json",
  "kind": "package",
  "name": "takos-computer",
  "version": "1.0.0",
  "description": "Browser automation and agent executor",
  "maintainer": "takos",
  "category": "tool",

  "tools": [
    {
      "name": "browser_open",
      "description": "Open a browser session"
    },
    {
      "name": "browser_goto",
      "description": "Navigate to a URL"
    },
    {
      "name": "browser_action",
      "description": "Perform a browser action (click, type, etc.)"
    },
    {
      "name": "browser_screenshot",
      "description": "Take a screenshot"
    },
    {
      "name": "browser_extract",
      "description": "Extract structured data from the page"
    },
    {
      "name": "browser_html",
      "description": "Get page HTML"
    },
    {
      "name": "browser_close",
      "description": "Close the browser session"
    }
  ],

  "containers": [
    {
      "name": "browser",
      "dockerfile": "apps/browser/Dockerfile",
      "port": 8080,
      "healthcheck": "/health"
    },
    {
      "name": "executor",
      "dockerfile": "apps/executor/Dockerfile",
      "port": 8080,
      "healthcheck": "/health"
    }
  ],

  "workers": [
    {
      "name": "executor-host",
      "config": "deploy/wrangler.executor-host.toml"
    },
    {
      "name": "browser-host",
      "config": "deploy/wrangler.browser-host.toml"
    }
  ],

  "bindings": {
    "TAKOS_CONTROL": {
      "type": "service",
      "description": "Service binding to main takos worker for Control RPC forwarding"
    },
    "EXECUTOR_PROXY_SECRET": {
      "type": "secret",
      "description": "Shared secret for executor-host ↔ main worker auth"
    }
  }
}
