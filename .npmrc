# pnpm settings for takos-computer monorepo

# Hoist dependencies for compatibility with tools that expect flat node_modules
shamefully-hoist=true

# Enforce peer dependency consistency
strict-peer-dependencies=true

# Use workspace protocol for linking packages
link-workspace-packages=true

# Prefer workspace packages over registry versions
prefer-workspace-packages=true

# Auto-install peer dependencies
auto-install-peers=true
