{
  "workspace": [
    "./apps/sandbox",
    "./packages/common",
    "./packages/cloudflare-compat",
    "./packages/computer-hosts",
    "./packages/sandbox-service",
    "./packages/dashboard"
  ],
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"],
    "types": ["node"]
  },
  "tasks": {
    "build:all": "deno task --cwd packages/computer-hosts build:all",
    "check:dist": "deno run --allow-read --allow-write --allow-run --allow-env --allow-sys scripts/check-dist.ts",
    "check": "deno check packages/common/src/**/*.ts packages/cloudflare-compat/src/**/*.ts packages/dashboard/src/**/*.ts packages/dashboard/src/**/*.tsx packages/dashboard/scripts/**/*.ts packages/dashboard/vite.config.ts packages/computer-hosts/src/**/*.ts packages/computer-hosts/scripts/**/*.ts packages/sandbox-service/src/**/*.ts",
    "dev:local": "deno task --cwd packages/computer-hosts dev:local",
    "test:all": "deno test --allow-all --parallel",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "lint": {
    "exclude": [
      "dist",
      "packages/dashboard/dist"
    ]
  },
  "fmt": {
    "exclude": [
      "dist",
      "packages/dashboard/dist",
      "packages/computer-hosts/src/gui/app.html",
      "packages/computer-hosts/src/gui/assets.generated.ts"
    ]
  }
}
