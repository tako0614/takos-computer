    "test:all": "bun run test",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@libsql/client": "^0.14.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
