{
  "name": "@takos-apps/takos-computer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "test": "LC_ALL=C bun test packages/common/src && LC_ALL=C bun test packages/cloudflare-compat/src && LC_ALL=C bun test packages/computer-hosts/src && LC_ALL=C bun test packages/sandbox-service/src",
    "test:all": "bun run test",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/bun": "latest",
    "@libsql/client": "^0.14.0",
    "@takos-computer/common": "workspace:*",
    "@takos-computer/cloudflare-compat": "workspace:*",
    "@takos-computer/computer-hosts": "workspace:*",
    "@takos-computer/dashboard": "workspace:*",
    "@takos-computer/sandbox-service": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
