{
  "name": "@takos-apps/takos-computer",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:local": "bun packages/computer-hosts/src/local-dev-simulator.ts",
    "build:dashboard": "bunx vite build packages/dashboard --config packages/dashboard/vite.config.ts && bun packages/dashboard/scripts/emit-assets.ts",
    "build:sandbox-host": "bun packages/computer-hosts/scripts/build-host.ts sandbox",
    "build:all": "bun run build:dashboard && bun run build:sandbox-host",
    "test": "LC_ALL=C bun test packages/computer-hosts/src && LC_ALL=C bun test packages/sandbox-service/src",
    "test:all": "bun run test",
    "check": "tsc --noEmit",
    "check:dist": "bun scripts/check-dist.ts"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "@cloudflare/containers": "^0.1.1",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@libsql/client": "^0.14.0",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
