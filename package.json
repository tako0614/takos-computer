{
  "name": "takos-computer",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Takos Computer — browser automation and agent executor services",
  "scripts": {
    "build:all": "pnpm -r build",
    "test:all": "pnpm -r test",
    "typecheck:all": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "clean:dist": "pnpm -r exec rm -rf dist",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "wrangler": "^4.61.0"
  },
  "pnpm": {
    "overrides": {
      "@cloudflare/workers-types": "^4.20260118.0",
      "esbuild": "^0.25.12",
      "wrangler": "^4.61.0",
      "hono": ">=4.12.4"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
