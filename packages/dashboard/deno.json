{
  "name": "@takos-computer/dashboard",
  "version": "1.0.0",
  "license": "MIT",
  "exports": "./src/App.tsx",
  "imports": {
    "solid-js": "npm:solid-js@^1.9.0",
    "solid-js/web": "npm:solid-js@^1.9.0/web",
    "@solidjs/router": "npm:@solidjs/router@^0.15.0",
    "vite": "npm:vite@^6.3.0",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.0",
    "vite-plugin-singlefile": "npm:vite-plugin-singlefile@^2.0.0"
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run --allow-sys --allow-ffi npm:vite",
    "build": "deno run --allow-read --allow-write --allow-env --allow-run --allow-sys --allow-ffi --node-modules-dir=none npm:vite build && deno run --allow-read --allow-write scripts/emit-assets.ts",
    "preview": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run --allow-sys --allow-ffi npm:vite preview"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  }
}
