{
  "name": "@takos-computer/computer-hosts",
  "version": "1.0.0",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./local-dev-simulator": "./src/local-dev-simulator.ts",
    "./sandbox-host": "./src/sandbox-host.ts",
    "./sandbox-session-types": "./src/sandbox-session-types.ts",
    "./proxy-token": "./src/proxy-token.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@cloudflare/containers": "npm:@cloudflare/containers@^0.1.1",
    "esbuild": "npm:esbuild@0.25.5",
    "hono": "npm:hono@^4.7.0"
  },
  "tasks": {
    "test": "deno test --allow-all src/",
    "dev:local": "deno run --allow-net --allow-env --allow-read --allow-write --allow-run src/local-dev-simulator.ts",
    "build:dashboard-assets": "cd ../dashboard && deno task build",
    "build:sandbox-host": "deno run --allow-read --allow-write --allow-env --allow-run --allow-sys scripts/build-host.ts sandbox",
    "build:all": "deno task build:dashboard-assets && deno task build:sandbox-host"
  }
}
